{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "AUTH_SECRET",
        "JWT_SECRET",
        "SEED_ADMIN_USERNAME",
        "SEED_ADMIN_PASSWORD",
        "DATABASE_URL",
        "NEXT_PUBLIC_URL" 
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}